{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://besafe.tw/schemas/route-catalog.json",
  "title": "HikeSafe reviewed route catalog",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "slug",
      "mountainName",
      "routeName",
      "region",
      "kind",
      "startLat",
      "startLng",
      "distanceKm",
      "designations",
      "elevationGainM",
      "elevationDifferenceM",
      "durationMinutes",
      "difficulty",
      "checkpoints",
      "evacuationPoints",
      "permitNotes",
      "sourceOrganization",
      "sourceUrl",
      "sourceVersion",
      "reviewedAt"
    ],
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
      "mountainName": { "type": "string", "minLength": 1 },
      "routeName": { "type": "string", "minLength": 1 },
      "region": { "type": "string", "minLength": 1 },
      "kind": { "enum": ["hundred_peak", "suburban"] },
      "startLat": { "type": ["number", "null"], "minimum": 21, "maximum": 26 },
      "startLng": { "type": ["number", "null"], "minimum": 119, "maximum": 123 },
      "distanceKm": { "type": "number", "exclusiveMinimum": 0 },
      "designations": {
        "type": "array",
        "items": {
          "type": "string",
          "pattern": "^taiwan_small_hundred_peak:(?:0(?:0[1-9]|[1-9][0-9])|100)$"
        }
      },
      "elevationGainM": { "type": ["integer", "null"], "minimum": 0 },
      "elevationDifferenceM": { "type": ["integer", "null"], "minimum": 0 },
      "durationMinutes": { "type": "integer", "exclusiveMinimum": 0 },
      "difficulty": { "type": "integer", "minimum": 0, "maximum": 6 },
      "checkpoints": { "$ref": "#/$defs/orderedPlaces" },
      "evacuationPoints": { "$ref": "#/$defs/optionalPlaces" },
      "permitNotes": { "type": ["string", "null"] },
      "sourceOrganization": { "type": "string", "minLength": 1 },
      "sourceUrl": { "type": "string", "format": "uri" },
      "sourceVersion": { "type": "string", "minLength": 1 },
      "reviewedAt": { "type": "string", "format": "date" }
    },
    "allOf": [
      {
        "anyOf": [
          {
            "properties": {
              "startLat": { "type": "null" },
              "startLng": { "type": "null" }
            }
          },
          {
            "properties": {
              "startLat": { "type": "number", "minimum": 21, "maximum": 26 },
              "startLng": { "type": "number", "minimum": 119, "maximum": 123 }
            }
          }
        ]
      }
    ]
  },
  "$defs": {
    "orderedPlaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "order"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "exclusiveMinimum": 0 }
        }
      }
    },
    "optionalPlaces": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "order"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
